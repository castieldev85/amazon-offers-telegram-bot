# =========================
# BOT TELEGRAM
# =========================
TELEGRAM_BOT_TOKEN=INSERISCI_TOKEN_BOT_TELEGRAM
ADMIN_IDS=1271567510

# =========================
# AMAZON PA-API / AFFILIATE
# =========================
AMAZON_PAAPI_ACCESS_KEY=INSERISCI_ACCESS_KEY
AMAZON_PAAPI_SECRET_KEY=INSERISCI_SECRET_KEY
AMAZON_PARTNER_TAG=tuotag-21
AMAZON_PAAPI_REGION=eu-west-1
AMAZON_PAAPI_HOST=webservices.amazon.it
AMAZON_PAAPI_MARKETPLACE=www.amazon.it

# =========================
# BRAND / GRAFICA
# =========================
BOT_BRAND_TEXT=t.me/amazon_offerte_sconti_coupon_top

# =========================
# QUALITÀ OFFERTE / PUBBLICAZIONE
# =========================
MIN_OFFER_SCORE=55
MAX_OFFERS_PER_USER_CYCLE=1
AUTOPOST_SLEEP_SECONDS=60
REFILL_CHECK_INTERVAL_SECONDS=60
WATCHLIST_CHECK_INTERVAL_SECONDS=900
ENABLE_INSTANT_POST_AFTER_REFILL=false
REFILL_BATCH_SIZE=2
INVALID_BUFFER_QUARANTINE_HOURS=12

# =========================
# SOCIAL OPZIONALI
# =========================
ENABLE_FACEBOOK_POSTING=true
ENABLE_INSTAGRAM_POSTING=true

# =========================
# PERCORSI LOCALI
# =========================
BUFFER_PATH=buffer_storage
USER_DATA_PATH=user_data.json
LINK_MAP_PATH=link_map.json
PUBLISHED_DB_PATH=published_products.json
SEARCH_RESULTS_DIR=search_results
REJECTED_OFFERS_PATH=rejected_offers.json

# Recupero dati ASIN
# true = se PA-API/HTML non trovano il prezzo, usa Selenium come ultima spiaggia.
ASIN_DETAIL_ENABLE_SELENIUM_FALLBACK=true
# Evita troppi Chrome aperti in parallelo durante il refill. Consigliato: 1.
ASIN_DETAIL_SELENIUM_MAX_PER_REFILL=1


# =========================
# FONTI TELEGRAM PUBBLICHE
# =========================
# La funzione dashboard “📥 Fonti Telegram” legge canali pubblici tramite preview t.me/s/nomecanale.
# Non richiede API ID/hash. Basta inserire il nome del canale dalla dashboard.
TELEGRAM_SOURCE_DEFAULT_LIMIT=30

# Fonti Telegram: file locale dove vengono salvati i canali sorgente
TELEGRAM_SOURCES_PATH=telegram_sources.json

# =========================
# FONTI TELEGRAM AVANZATE / TELETHON
# =========================
# false = usa solo preview pubblica t.me/s/nomecanale
# true  = usa un account Telegram reale tramite Telethon, poi fallback preview pubblica
TELETHON_ENABLED=false
# Crea API_ID e API_HASH da https://my.telegram.org → API development tools
TELETHON_API_ID=
TELETHON_API_HASH=
# File sessione creato da: python telethon_login.py
TELETHON_SESSION=telegram_user.session
# Numero massimo di foto da scaricare per ogni scansione fonte Telethon
TELETHON_MAX_MEDIA_DOWNLOADS=5

# Cartella persistente per foto importate da fonti Telegram/Telethon
TELEGRAM_SOURCE_MEDIA_PATH=telegram_source_media

# Pulizia immagini importate da fonti Telegram
TELEGRAM_SOURCE_CLEAN_MEDIA=true
TELEGRAM_SOURCE_TRIM_BOTTOM_WATERMARK=true

# Qualità pubblicazione
# true = non pubblica offerte senza una foto prodotto reale; evita placeholder bianchi nel canale.
REQUIRE_PRODUCT_IMAGE=true

# Validazione prezzi Fonti Telegram
# false = se Amazon non conferma il prezzo live, l'offerta viene scartata. Consigliato per evitare prezzi sbagliati.
# true  = consente di usare il prezzo scritto dal post sorgente anche se Amazon/PA-API non lo conferma. Più offerte, ma meno sicuro.
TELEGRAM_SOURCE_ALLOW_UNVERIFIED_PRICE=false
# Differenza massima ammessa tra prezzo fonte Telegram e prezzo live Amazon prima di considerare la fonte non affidabile.
TELEGRAM_SOURCE_PRICE_MAX_DIFF_PERCENT=12

# Numero pagine categoria di default quando l'utente non ha ancora scelto dalla dashboard
DEFAULT_CATEGORY_MAX_PAGES=2
